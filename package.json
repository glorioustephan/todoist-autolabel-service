{
  "name": "@glorioustephan/todoist-autolabel",
  "version": "0.0.0",
  "description": "Automatically classify and label Todoist Inbox tasks with Claude AI using Structured Outputs.",
  "keywords": [
    "todoist",
    "autolabel",
    "claude",
    "anthropic",
    "ai",
    "classification",
    "productivity",
    "labels",
    "structured-outputs",
    "cli"
  ],
  "author": "glorioustephan",
  "license": "MIT",
  "homepage": "https://glorioustephan.github.io/todoist-autolabel-service/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/glorioustephan/todoist-autolabel-service.git"
  },
  "bugs": {
    "url": "https://github.com/glorioustephan/todoist-autolabel-service/issues"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "todoist-autolabel": "dist/service.js"
  },
  "files": [
    "dist",
    "env.example",
    "labels.example.json",
    "LICENSE",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/service.js",
    "dev": "tsx src/service.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json",
    "validate-env": "tsx src/validate-env.ts",
    "commit": "cz",
    "prepublishOnly": "pnpm run typecheck && pnpm run test && pnpm run build"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.71.0",
    "@doist/todoist-sdk": "^10.1.3",
    "better-sqlite3": "^11.3.0",
    "chalk": "^5.3.0",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.5.0",
    "@vitest/coverage-v8": "^2.0.5",
    "@vitest/ui": "^2.0.5",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "happy-dom": "^15.7.4",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  },
  "engines": {
    "node": ">=20.18.1"
  }
}
