# Todoist Autolabel Service Configuration
# Copy this file to .env and fill in your values

# ============================================
# REQUIRED
# ============================================

# Todoist API Token
# Get from: https://todoist.com/app/settings/integrations/developer
TODOIST_API_TOKEN=your_todoist_token_here

# Anthropic API Key
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_key_here

# ============================================
# CLAUDE CONFIGURATION
# ============================================

# Claude model to use for classification
# Structured Outputs requires Haiku 4.5+, Sonnet 4.5+, or Opus 4+
# Options: claude-haiku-4-5-20251001, claude-sonnet-4-5-20250929, claude-opus-4-20250514
# Default: claude-haiku-4-5-20251001 (recommended — cheapest, fast, supports structured outputs)
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Maximum labels to assign per task (default: 5)
MAX_LABELS_PER_TASK=5

# ============================================
# SERVICE CONFIGURATION
# ============================================

# Polling interval in milliseconds (default: 15000 = 15 seconds)
POLL_INTERVAL_MS=15000

# Maximum error log entries before FIFO purge (default: 1000)
MAX_ERROR_LOGS=1000

# SQLite database path (default: ./data/todoist.db)
DB_PATH=./data/todoist.db

# Log level: debug, info, warn, error (default: info)
LOG_LEVEL=info

# ============================================
# BACKFILL & RETRY SWEEP
# ============================================
# Without these, a task that fails 3 attempts is marked `failed` and never
# retried — even if it's still sitting unlabelled in your Inbox. These knobs
# fix that.

# On service start, reset previously-failed Inbox tasks so they get another
# shot. Useful after a service outage or a model upgrade. (default: true)
BACKFILL_ON_START=true

# How often to re-run the reset sweep while the service is running.
# Set to 0 to disable. Default: 86400000 (24 hours).
BACKFILL_INTERVAL_MS=86400000

# Minimum gap between successive retries of the SAME task, in ms.
# Protects against hot loops on genuinely-unclassifiable tasks (they fall
# back to ~1 attempt per cooldown interval). Default: 3600000 (1 hour).
BACKFILL_COOLDOWN_MS=3600000

# ============================================
# PATHS (optional — defaults are CWD-relative)
# ============================================

# Path to your label taxonomy. Defaults to ./labels.json in the working directory.
# LABELS_PATH=./labels.json
